# Root environment variables example for Campus Placement Portal
# Use this file as a template for Render or local development.

MONGO_URI=mongodb://localhost:27017/placement_portal
EMAIL_SERVICE=gmail
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password_or_smtp_password
EMAIL_FROM=Campus Placement <your.email@gmail.com>
ADMIN_EMAIL=admin@yourdomain.com
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_strong_secret
ADMIN_CREATION_TOKEN=your_secret_admin_token_here
PORT=5000

# IMPORTANT:
# - For Gmail SMTP, use an App Password, not your normal Gmail password.
# - For Render hosting, if outbound SMTP is blocked, use SendGrid API:
#   SENDGRID_API_KEY=SG.xxxxxxxx
#   EMAIL_FROM=Campus Placement <no-reply@yourdomain.com>
# - Do not commit real secret values to source control.

# Example .env
MONGO_URI=mongodb://localhost:27017/placement_portal
EMAIL_SERVICE=gmail
EMAIL_USER=your.email@gmail.com
EMAIL_PASS=your_app_password_or_smtp_password
EMAIL_FROM=Campus Placement <your.email@gmail.com>
# For Gmail, generate an App Password and use it here.
# Regular Gmail account passwords are often rejected by SMTP.
# SendGrid: set SENDGRID_API_KEY to prefer SendGrid over SMTP settings.
# Example:
# SENDGRID_API_KEY=SG.xxxxxxx
# When using SendGrid SMTP, the mailer will use user 'apikey' and the API key as the password.
# Optional custom SMTP settings instead of EMAIL_SERVICE
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
ADMIN_EMAIL=admin@yourdomain.com
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace_with_strong_secret
ADMIN_CREATION_TOKEN=your_secret_admin_token_here
# Set ADMIN_CREATION_TOKEN to a strong secret value.
# This token is required in the registration request to create an admin account.
# Keep this secret and only share with authorized users who should be admins.
PORT=5000
